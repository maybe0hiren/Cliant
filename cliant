#!/home/Hiren/Documents/Cache/Cliant/env/bin/python

import os
import json
import subprocess
import traceback
from dotenv import load_dotenv
from google import genai


load_dotenv()
llmKey = os.getenv("GEMINI_KEY")
if not llmKey:
    raise RuntimeError("LLM not reachable")

client = genai.Client(api_key=llmKey)
modelName = "models/gemini-2.5-flash"

userId = os.getlogin()
profileDb = "userCommandProfiles.json"

sessionMemory = {
    "tasks": [],
    "executedCommands": [],
    "errors": [],
    "fixAttempts": {}
}

sessionCwd = os.getcwd()


def askLLM(prompt, retries=2):
    for _ in range(retries + 1):
        try:
            r = client.models.generate_content(
                model=modelName,
                contents=prompt
            )
            text = (r.text or "").strip()
            if text:
                return text
        except Exception as e:
            sessionMemory["errors"].append(str(e))
    return ""


def normalizeCommands(raw):
    return [p.strip() for p in raw.replace(",", "\n").split("\n") if p.strip()]


def loadProfiles():
    if not os.path.exists(profileDb):
        return {}
    with open(profileDb, "r") as f:
        return json.load(f)


def saveProfiles(data):
    with open(profileDb, "w") as f:
        json.dump(data, f, indent=2)


def recordCommandUsage(cmd):
    profiles = loadProfiles()
    user = profiles.setdefault(userId, {})
    user[cmd] = user.get(cmd, 0) + 1
    saveProfiles(profiles)


def getFrequentCommands(limit=5):
    profiles = loadProfiles()
    user = profiles.get(userId, {})
    return sorted(user, key=user.get, reverse=True)[:limit]


def isDangerousCommand(cmd):
    return any(p in cmd for p in [
        "rm -rf /", "rm -rf /*", "mkfs", "dd if=", ":(){:|:&};:"
    ])


def requiresExtraConfirmation(cmd):
    return cmd.strip().startswith(
        ("rm ", "mv ", "cp ", "chmod ", "chown ")
    )


def safeRunCommand(command):
    global sessionCwd
    try:
        cmd = command.replace("`", "").strip()

        if cmd.startswith("cd "):
            target = os.path.abspath(os.path.join(sessionCwd, cmd[3:].strip()))
            if os.path.isdir(target):
                sessionCwd = target
                return f"Changed directory to {sessionCwd}", "", "ok"
            return "", f"No such directory: {target}", "error"

        if isDangerousCommand(cmd):
            return "", "Blocked dangerous command", "error"

        useShell = any(x in cmd for x in ["|", "&&", "||", ">", "<"])

        r = subprocess.run(
            cmd if useShell else cmd.split(),
            shell=useShell,
            executable="/bin/bash" if useShell else None,
            capture_output=True,
            text=True,
            timeout=30,
            cwd=sessionCwd
        )

        if r.stderr.strip():
            return r.stdout.strip(), r.stderr.strip(), "error"

        return r.stdout.strip(), "", "ok"

    except subprocess.TimeoutExpired:
        print("⏳ Command running longer than expected. Letting it continue.")
        return "", "", "timeout"

    except Exception as e:
        return "", str(e), "error"


def collectSystemInfo(task, error):
    with open("sysInfo.json") as f:
        known = json.load(f)

    req = askLLM(f"""
                    Task:
                    {task}
                    Command error:
                    {error}
                    Known system info:
                    {",".join(known.keys())}
                    Return ONLY missing system info names.
                    Comma-separated.
                """)

    reqKeys = normalizeCommands(req)
    if not reqKeys:
        return {}

    cmds = normalizeCommands(askLLM(f"""
                                        System info needed:
                                        {",".join(reqKeys)}
                                        Known:
                                        {known}
                                        Return ONLY commands.
                                    """))

    info = {}
    for key, cmd in zip(reqKeys, cmds):
        out, _, status = safeRunCommand(cmd)
        if status == "ok":
            info[key] = out

    return info


def handleCommandError(task, cmd, err):
    attempts = sessionMemory["fixAttempts"].get(cmd, 0)
    if attempts >= 1:
        print("❌ Auto-fix failed. Manual intervention required.")
        return

    sessionMemory["fixAttempts"][cmd] = attempts + 1

    sysInfo = collectSystemInfo(task, err)

    fix = askLLM(f"""
                    You are an Arch Linux expert.
                    Task:
                    {task}
                    Failed command:
                    {cmd}
                    Error:
                    {err}
                    System info:
                    {sysInfo}
                    Return ONLY corrected command.
                """)

    if not fix or isDangerousCommand(fix):
        return

    print(f"Suggested fix: {fix}")
    if input("Execute fix? [Y/n]: ").lower() != "y":
        return

    out, _, status = safeRunCommand(fix)
    sessionMemory["executedCommands"].append(fix)

    if status == "ok":
        print(out)
        recordCommandUsage(fix)


def generateTaskCommands(task):
    frequent = getFrequentCommands()

    raw = askLLM(f"""
                    You are an Arch Linux command executor.
                    User habits:
                    {", ".join(frequent) if frequent else "None"}
                    Task:
                    {task}
                    CWD:
                    {sessionCwd}
                    History:
                    {sessionMemory["executedCommands"]}
                    Return ONLY executable commands.
                """)

    cmds = normalizeCommands(raw)
    if not cmds:
        raise RuntimeError("LLM failed to generate commands")

    return cmds


def executeTaskCommands(task, cmds):
    print(askLLM(f"""
                    Explain commands briefly.
                    Format:
                    <cmd> : <job>, THREATS: <NONE or serious>
                    Commands:
                    {",".join(cmds)}
                """))

    if input("Execute? [Y/n]: ").lower() != "y":
        return

    for cmd in cmds:
        if requiresExtraConfirmation(cmd):
            if input(f"Extra confirmation for `{cmd}` [Y/n]: ").lower() != "y":
                continue

        out, err, status = safeRunCommand(cmd)
        sessionMemory["executedCommands"].append(cmd)

        if status == "ok":
            print(out)
            recordCommandUsage(cmd)
        elif status == "error":
            handleCommandError(task, cmd, err)


def main():
    print("CLIANT session started.")
    try:
        while True:
            task = input("> ").strip()
            if not task:
                continue

            sessionMemory["tasks"].append(task)

            cmds = generateTaskCommands(task)
            executeTaskCommands(task, cmds)

    except KeyboardInterrupt:
        print("\nSession terminated safely.")
    except Exception as e:
        print("❌", e)
        traceback.print_exc()


if __name__ == "__main__":
    main()