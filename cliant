import os
from dotenv import load_dotenv
from google import genai
import json
import subprocess
import traceback

# Code Setup
load_dotenv()
LLM = os.getenv("GEMINI_KEY")
if not LLM:
    raise RuntimeError("LLM not reachable")
client = genai.Client(api_key=LLM)
modelName = "models/gemini-2.5-flash"

# Session-based memory
SESSION_MEMORY = {
    "tasks": [],
    "executed_commands": [],
    "errors": []
}

# Session working directory
SESSION_CWD = os.getcwd()

# Send prompt to LLM and get Result
def askLLM(prompt):
    try:
        response = client.models.generate_content(
            model=modelName,
            contents=prompt,
        )
        return response.text.strip()
    except Exception as e:
        SESSION_MEMORY["errors"].append(str(e))
        return ""

# Safety checks for commands
def isDangerousCommand(cmd):
    dangerous_patterns = [
        "rm -rf /",
        "rm -rf /*",
        "mkfs",
        "dd if=",
        ":(){:|:&};:"
    ]
    return any(pat in cmd for pat in dangerous_patterns)

def requires_extra_confirmation(cmd):
    risky_keywords = ["rm ", "mv ", "cp ", "chmod ", "chown "]
    return any(cmd.strip().startswith(k) for k in risky_keywords)

# Safe command execution wrapper (DIRECTORY-AWARE)
def safeRunCommand(command):
    global SESSION_CWD
    try:
        cmd = command.replace("`", "").strip()

        # Handle directory navigation
        if cmd.startswith("cd "):
            target = cmd[3:].strip()
            new_path = os.path.abspath(os.path.join(SESSION_CWD, target))
            if os.path.isdir(new_path):
                SESSION_CWD = new_path
                return f"Changed directory to {SESSION_CWD}", ""
            return "", f"Directory does not exist: {target}"

        if isDangerousCommand(cmd):
            return "", "Blocked dangerous command"

        use_shell = any(x in cmd for x in ["|", "&&", "||", ">", "<"])

        result = subprocess.run(
            cmd if use_shell else cmd.split(),
            shell=use_shell,
            executable="/bin/bash" if use_shell else None,
            capture_output=True,
            text=True,
            timeout=30,
            cwd=SESSION_CWD
        )

        return result.stdout.strip(), result.stderr.strip()

    except subprocess.TimeoutExpired:
        return "", "Command timed out"
    except Exception as e:
        return "", str(e)

# Error recovery handler
def handleCommandError(failed_command, error_message):
    prompt = f"""
                You are an expert Arch Linux troubleshooter.

                System policy:
                - Assume the system is already set up and functional.
                - DO NOT suggest installing packages.
                - DO NOT suggest downloading anything.
                - DO NOT suggest enabling services.

                Command:
                {failed_command}

                Error:
                {error_message}

                Session context:
                {SESSION_MEMORY["executed_commands"]}

                Return ONLY a corrected raw command.
                NO explanation.
                NO markdown.
                NO backticks.
            """

    new_command = askLLM(prompt).strip()
    if not new_command or isDangerousCommand(new_command):
        return

    if input(f"Execute fix `{new_command}` ? [Y/n]: ").lower() != "y":
        return

    stdout, stderr = safeRunCommand(new_command)
    SESSION_MEMORY["executed_commands"].append(new_command)
    if stderr:
        SESSION_MEMORY["errors"].append(stderr)

# Get relevant system information
def getReqSysInfo(userMessage):
    with open("sysInfo.json") as f:
        data = json.load(f)

    prompt = f"""
            User task:
            {userMessage}

            Return ONLY required system info names.
            Comma-separated.
            NO explanation.
            Skip known: {",".join(data.keys())}
            """

    reqSysInfo = askLLM(prompt).split(",")
    return {x.strip(): [None, None] for x in reqSysInfo if x.strip()}

# Get the required system info
def retrieveSysInfo(sysReqDict):
    with open("sysInfo.json") as f:
        data = json.load(f)

    prompt = f"""
            System info needed:
            {",".join(sysReqDict.keys())}

            Known:
            {data}

            Return ONLY commands.
            Comma-separated.
            NO explanation.
            NO markdown.
        """

    commands = askLLM(prompt).split(",")

    i = 0
    for key in sysReqDict:
        if sysReqDict[key] == [None, None] and i < len(commands):
            sysReqDict[key] = [1, commands[i].strip()]
            i += 1

    return sysReqDict

# Ask the user what each command does and execute if permitted
def askAndExec(sysReqDict):
    commands, keys = [], []
    for k in sysReqDict:
        if sysReqDict[k][0] == 1:
            keys.append(k)
            commands.append(sysReqDict[k][1])

    if not commands:
        return sysReqDict

    print(askLLM(f"""
            Explain each command briefly.
            Format ONLY:
            <command> : <job>, THREATS: <NONE or serious>

            Commands:
            {",".join(commands)}
        """))

    if input("Execute? [Y/n]: ").lower() != "y":
        return sysReqDict

    for i, cmd in enumerate(commands):
        out, err = safeRunCommand(cmd)
        SESSION_MEMORY["executed_commands"].append(cmd)
        if err:
            SESSION_MEMORY["errors"].append(err)
            handleCommandError(cmd, err)
        else:
            sysReqDict[keys[i]] = [3, out]

    return sysReqDict

# Generate task execution commands (FORCED EXECUTION)
def generateTaskCommands(task, sysReqDict):
    prompt = f"""
            You are an Arch Linux runtime command executor.

            System policy:
            - Assume the system is already set up and functional.
            - DO NOT suggest installing packages.
            - DO NOT suggest downloading anything.
            - DO NOT suggest enabling services.
            - Treat this as a runtime action, not setup.

            IMPORTANT:
            - You MUST generate at least one command.
            - Returning an empty response is NOT allowed.
            - The task MUST be executed.

            Task:
            {task}

            CWD:
            {SESSION_CWD}

            History:
            {SESSION_MEMORY["executed_commands"]}

            Return ONLY raw commands.
            Comma-separated.
            NO explanation.
        """

    response = askLLM(prompt).strip()
    if not response:
        SESSION_MEMORY["errors"].append("LLM returned empty command set")
        return []

    return [c.strip() for c in response.split(",") if c.strip()]

# Execute task commands
def executeTaskCommands(taskCommands):
    if not taskCommands:
        print("No executable commands generated.")
        return

    print(askLLM(f"""
            Explain commands briefly.
            Format ONLY:
            <command> : <job>, THREATS: <NONE or serious>

            Commands:
            {",".join(taskCommands)}
        """))

    if input("Execute? [Y/n]: ").lower() != "y":
        return

    for cmd in taskCommands:
        out, err = safeRunCommand(cmd)
        SESSION_MEMORY["executed_commands"].append(cmd)
        if err:
            SESSION_MEMORY["errors"].append(err)
            handleCommandError(cmd, err)
        else:
            print(out)

# Main loop
def main():
    print("CLIANT session started.")
    try:
        while True:
            task = input("> ")
            SESSION_MEMORY["tasks"].append(task)

            sysReqDict = getReqSysInfo(task)
            sysReqDict = retrieveSysInfo(sysReqDict)
            sysReqDict = askAndExec(sysReqDict)

            cmds = generateTaskCommands(task, sysReqDict)
            executeTaskCommands(cmds)

    except KeyboardInterrupt:
        print("\nSession terminated safely.")

if __name__ == "__main__":
    main()